{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --ignore-scripts",
  "crons": [
    { "path": "/api/cron/scrape-importyeti", "schedule": "0 11 * * *" },
    { "path": "/api/cron/enqueue-enrichment", "schedule": "30 11 * * *" },
    { "path": "/api/cron/run-enrichment", "schedule": "0 12 * * *" },
    { "path": "/api/cron/score-leads", "schedule": "0 13 * * *" },
    { "path": "/api/cron/send-batch", "schedule": "0 14 * * 1-5" },
    { "path": "/api/cron/digest-daily", "schedule": "0 22 * * 1-5" }
  ],
  "functions": {
    "app/api/cron/run-enrichment/route.ts": { "maxDuration": 300 },
    "app/api/cron/send-batch/route.ts": { "maxDuration": 300 },
    "app/api/sources/scrape/route.ts": { "maxDuration": 300 },
    "app/api/sources/upload/route.ts": { "maxDuration": 60 }
  }
}
